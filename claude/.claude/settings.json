            "Bash(gh run download:*)",
            "Bash(gh workflow list:*)",
            "Bash(gh workflow view:*)",
            "Bash(gh secret list:*)",
            "Bash(gh auth status)",
            "Bash(uv pip list:*)",
            "Bash(uv pip show:*)",
            "Bash(uv pip freeze:*)",
            "Bash(uv pip install:*)",
            "Bash(uv run:*)",
            "Bash(uv sync:*)",
            "Bash(uv lock:*)",
            "Bash(uv venv:*)",
            "Bash(uv python list:*)",
            "Bash(uv tool list:*)",
            "Bash(uv tree:*)",
            "Bash(npm install:*)",
            "Bash(npm ci:*)",
            "Bash(npm test:*)",
            "Bash(npm run test:*)",
            "Bash(npm run lint:*)",
            "Bash(npm run build:*)",
            "Bash(npm run dev:*)",
            "Bash(npm run start:*)",

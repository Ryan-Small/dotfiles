        "deny": [
            "Read(./**/.env*)",
            "Read(~/.ssh/**)",
            "Read(~/.aws/**)"
        ],
        "ask": [],
        "defaultMode": "default",
        "disableBypassPermissionsMode": "disable",
        "additionalDirectories": []
    },
    "statusLine": {
        "type": "command",
        "command": "~/.claude/statusline.sh",
        "padding": 0
    },
    "spinnerVerbs": {
        "mode": "replace",
        "verbs": [
            "Jacking in",
            "Flatling the ICE",
            "Console-cowboying",
            "Neuromancing",
            "Wintermuting",
            "Burning chrome",
            "Tracing the grid",
            "Ghosting the net",
            "Decking the sprawl",
            "Punching ice",
            "Riding the datastream",
            "Uplinkin",
            "Hardwiring",
            "Flipping the bit",
            "Compiling the construct",
            "Jacking the matrix",
            "Splicing the code",
            "Flatlining"
        ]
    },
    "alwaysThinkingEnabled": true,
    "effortLevel": "high",
    "companyAnnouncements": [
        "The sky above the port was the color of television, tuned to a dead channel.",
        "The future is already here — it's just not evenly distributed.",
        "Cyberspace. A consensual hallucination experienced daily by billions.",
        "Night City was like a deranged experiment in social Darwinism, designed by a bored researcher who kept one thumb permanently on the fast-forward button.",
        "Before you go, kid, let me tell you something. The matrix has its roots in primitive arcade games.",
        "I've seen things you people wouldn't believe. Attack ships on fire off the shoulder of Orion.",
        "All those moments will be lost in time, like tears in rain.",
        "It's too bad she won't live. But then again, who does?",
        "The light that burns twice as bright burns half as long.",
        "When you are wrestling for possession of a sword, the man with the handle always wins.",
        "The Deliverator belongs to an elite order, a hallowed subcategory.",
        "We are all connected; to each other, biologically. To the earth, chemically. To the rest of the universe, atomically.",
        "Information wants to be free. Information also wants to be expensive. That tension will not go away.",
        "The body was meat. The mind was software. The soul was the ghost in the machine."
    ],
    "enabledPlugins": {}
}

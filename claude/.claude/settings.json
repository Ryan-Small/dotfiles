            "Bash(git worktree move:*)",
            "Edit",
            "MultiEdit",
            "Write",
            "Bash(node:*)",
            "Bash(python:*)",
            "Bash(jq:*)",
            "Bash(gh pr list:*)",
            "Bash(gh pr view:*)",
            "Bash(gh pr diff:*)",
            "Bash(gh pr checks:*)",
            "Bash(gh issue list:*)",
            "Bash(gh issue view:*)",
            "Bash(gh repo list:*)",

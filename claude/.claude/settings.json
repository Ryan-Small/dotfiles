{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "cleanupPeriodDays": 30,
    "env": {
        "DISABLE_TELEMETRY": "1"
    },
    "attribution": {
        "commit": "",
        "pr": ""
    },
    "permissions": {
        "allow": [
            "Read",
            "Glob",
            "Grep",
            "LS",
            "Bash(git status)",
            "Bash(git log:*)",

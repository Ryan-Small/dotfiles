            "Bash(gradle dependencies:*)",
            "Bash(gradle tasks:*)",
            "Bash(gradle assemble:*)",
            "Bash(./gradlew build:*)",
            "Bash(./gradlew test:*)",
            "Bash(./gradlew check:*)",
            "Bash(./gradlew clean:*)",
            "Bash(./gradlew dependencies:*)",
            "Bash(./gradlew tasks:*)",
            "Bash(./gradlew assemble:*)",
            "Bash(aws s3 ls:*)",
            "Bash(aws s3api get-bucket-*:*)",
            "Bash(aws s3api list-*:*)",
            "Bash(aws s3api head-*:*)",
            "Bash(aws ec2 describe-*:*)",
